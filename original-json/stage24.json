  {
    "name": "彦麻呂",
    "message": "はい。"
  },
  {
    "name": "咲美",
    "message": "先生と二人きりで？"
  },
  {
    "name": "彦麻呂",
    "message": "…そう言えば二人きりでしたねぇ。"
  },
  {
    "name": "夫",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "え゛…。"
  },
  {
    "name": "咲美",
    "message": "マ、マー君？"
