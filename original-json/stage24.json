  {
    "name": "咲美",
    "message": "え、えーと…。"
  },
  {
    "name": "夫",
    "message": "ね、ね、ね、ね？"
  },
  {
    "name": "咲美",
    "message": "せ、先生さえ良ければ…。"
  },
  {
    "name": "夫",
    "message": "こ、これで決まりだ。はあっ、はあっ…。"
  },
