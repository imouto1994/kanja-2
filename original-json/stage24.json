[
  {
    "message": "…そして午後９時…"
  },
  {
    "message": "ピンポーン。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "咲美",
    "message": "はーい。"
  },
  {
    "name": "咲美",
    "message": "いらっしゃい、先生。"
  },
  {
    "name": "彦麻呂",
    "message": "お邪魔しますぅ。"
  },
  {
    "name": "夫",
    "message": "い、いらっしゃいませ。"
  },
  {
    "name": "彦麻呂",
    "message": "こんばんはぁ。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "…何故にスーツを？"
  },
  {
    "name": "夫",
    "message": "っ、色々と事情がありまして。"
  },
  {
    "name": "彦麻呂",
    "message": "どのような事情でしょう？"
  },
  {
    "name": "夫",
    "message": "ですから色々です。"
  },
  {
    "name": "彦麻呂",
    "message": "…色々。"
  },
  {
    "name": "夫",
    "message": "ご自分のおウチだと思って、ゆっくりくつろいで下さい。今日のボクは料理の担当なので、大したおかまいもできませんが。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "…は？"
  },
  {
    "message": "旦那はそれだけ言い残し。"
  },
  {
    "message": "一旦はずしたエプロンを再び身に纏う。"
  },
  {
    "name": "咲美",
    "message": "っ、今日はマー君の手料理だよ。"
  },
  {
    "name": "彦麻呂",
    "message": "みたいですねぇ。"
  },
  {
    "name": "咲美",
    "message": "私には先生のお相手を、ずっとしてて欲しい、って。"
  },
  {
    "name": "彦麻呂",
    "message": "キッチンに立ってると、スーツ姿が浮いてますぅ。"
  },
  {
    "name": "咲美",
    "message": "っ、先生もそう思った？"
  },
  {
    "name": "彦麻呂",
    "message": "何やら事情があると言ってましたが。"
  },
  {
    "name": "咲美",
    "message": "実は…あの…。"
  },
  {
    "message": "奥さんはかなり言い辛そう。"
  },
  {
    "message": "旦那が背中向きなのを確認し。"
  },
  {
    "message": "ボショボショ小声で話し始めた。"
  },
  {
    "name": "咲美",
    "message": "仕事があるから、出掛けるみたい。"
  },
  {
    "name": "彦麻呂",
    "message": "は、はあ？"
  },
  {
    "name": "咲美",
    "message": "すぐ戻ってくるから、先生を、帰しちゃダメだよ、って。"
  },
  {
    "name": "彦麻呂",
    "message": "何ですか、そりゃ。"
  },
  {
    "name": "咲美",
    "message": "本当に、ごめん。普通、招いた本人が…。"
  },
  {
    "name": "夫",
    "message": "咲美～っ。"
  },
  {
    "name": "咲美",
    "message": "は、はい。"
  },
  {
    "name": "夫",
    "message": "いつも使ってる大きなお皿は？"
  },
  {
    "name": "咲美",
    "message": "っ、扉を開けて、右側の真ん中。"
  },
  {
    "name": "夫",
    "message": "…真ん中、真ん中…あった…。"
  },
  {
    "name": "咲美",
    "message": "あとは平気？"
  },
  {
    "name": "夫",
    "message": "ガラスの器も見つからないなぁ。模様の入った、あの綺麗なやつ。"
  },
  {
    "name": "咲美",
    "message": "あれは大きいお皿があった、上の棚。"
  },
  {
    "name": "夫",
    "message": "…上の棚、上の棚…見つけた…。"
  },
  {
    "name": "咲美",
    "message": "もうちょっとで完成しそう？"
  },
  {
    "name": "夫",
    "message": "あとは盛り付けを残すのみ。"
  },
  {
    "name": "咲美",
    "message": "っ、私がやろうか？"
  },
  {
    "name": "夫",
    "message": "そう？"
  },
  {
    "message": "断ると思った予想に反し。"
  },
  {
    "message": "呆気ないくらい簡単に旦那は譲る。"
  },
  {
    "name": "夫",
    "message": "では、先生。"
  },
  {
    "name": "彦麻呂",
    "message": "はい。"
  },
  {
    "name": "夫",
    "message": "僕はちょっと失礼します。"
  },
  {
    "name": "彦麻呂",
    "message": "どちらへ？"
  },
  {
    "name": "夫",
    "message": "言うほどの場所ではありません。"
  },
  {
    "name": "彦麻呂",
    "message": "…そうですかぁ。"
  },
  {
    "name": "夫",
    "message": "ここがご自宅だと思って、本気でくつろいで下さい。"
  },
  {
    "name": "彦麻呂",
    "message": "やたら念を押しますねぇ。"
  },
  {
    "name": "夫",
    "message": "何でも自由に使って貰って結構です。お風呂でもお布団でもティッシュでも、ここにある全てが先生の所有物だと思って。"
  },
  {
    "name": "彦麻呂",
    "message": "わかりましたぁ。"
  },
  {
    "name": "夫",
    "message": "じゃあ咲美、後は宜しく。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "…本当に行っちゃいましたねぇ。"
  },
  {
    "name": "咲美",
    "message": "…お腹は空いてる？"
  },
  {
    "name": "彦麻呂",
    "message": "夕御飯を御一緒するという話でしたので。"
  },
  {
    "name": "咲美",
    "message": "じゃあ、食べよ。"
  },
  {
    "name": "彦麻呂",
    "message": "はい、せっかく旦那さんが作ってくれたわけですし。"
  },
  {
    "name": "咲美",
    "message": "テーブルに運ぶから、先生は先に座ってて。"
  },
  {
    "name": "彦麻呂",
    "message": "私も手伝いましょうか？"
  },
  {
    "name": "咲美",
    "message": "先生はお客様だから。"
  },
  {
    "message": "旦那が外したエプロンをかけ。"
  },
  {
    "message": "テキパキと準備をこなしてた。"
  },
  {
    "message": "奥さんの家で彼女と差し向かい。"
  },
  {
    "message": "変な空気に二人して戸惑いながら。"
  },
  {
    "message": "それでも並んだ料理に手をつけ始める。"
  },
  {
    "name": "咲美",
    "message": "本当にごめんね。"
  },
  {
    "name": "彦麻呂",
    "message": "はい？"
  },
  {
    "name": "咲美",
    "message": "誘ったマー君がいないなんて…はぁ。"
  },
  {
    "name": "彦麻呂",
    "message": "気にしないで下さいな。"
  },
  {
    "name": "咲美",
    "message": "もう私にもよくわからない。"
  },
  {
    "name": "彦麻呂",
    "message": "その意見には賛成ですぅ。"
  },
  {
    "message": "もぐもぐもぐ…。"
  },
  {
    "name": "彦麻呂",
    "message": "…これは？"
  },
  {
    "name": "咲美",
    "message": "手作りのヤキトリだよ。"
  },
  {
    "name": "彦麻呂",
    "message": "ササミの間に挟まってるのは…。"
  },
  {
    "name": "咲美",
    "message": "たぶん焼いたニンニク。"
  },
  {
    "name": "彦麻呂",
    "message": "丸ごとですかぁ？"
  },
  {
    "message": "ぱくっ。"
  },
  {
    "name": "彦麻呂",
    "message": "ありゃ。"
  },
  {
    "name": "咲美",
    "message": "どしたの？"
  },
  {
    "name": "彦麻呂",
    "message": "美味しいですねぇ。"
  },
  {
    "name": "咲美",
    "message": "…どれどれ。"
  },
  {
    "message": "ぱくっ。"
  },
  {
    "name": "咲美",
    "message": "あ…本当に美味しい。"
  },
  {
    "name": "彦麻呂",
    "message": "こちらはトロロ芋ですかねぇ。"
  },
  {
    "name": "咲美",
    "message": "うん。"
  },
  {
    "message": "ずずずずず…。"
  },
  {
    "name": "彦麻呂",
    "message": "薄味の味付けが良い加減ですぅ。"
  },
  {
    "name": "咲美",
    "message": "添えてあるオクラも、何だかオシャレ。"
